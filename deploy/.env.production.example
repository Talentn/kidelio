# ⚠️  FIRST-TIME SETUP ONLY — run once:
#       cp deploy/.env.production.example deploy/.env.production
#     NEVER copy over an existing deploy/.env.production — you will wipe secrets
#     (Meta tokens, Google OAuth, etc.) and can break Rails boot.
#
# ─── Rails ────────────────────────────────────────────────────────────────────
# Copy the contents of api/config/master.key (never commit that file!)
RAILS_MASTER_KEY=

# Optional — only set if you are NOT using credentials.yml.enc via RAILS_MASTER_KEY.
# If you leave this unset, Rails reads secret_key_base from encrypted credentials.
# Generate with: openssl rand -hex 64
# SECRET_KEY_BASE=

RAILS_ENV=production
# Puma HTTP threads — 12 GB VPS: 20 is fine; keep equal to database max_connections
RAILS_MAX_THREADS=20
RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=true
RAILS_LOG_LEVEL=info

# Background jobs (Solid Queue inside Puma)
SOLID_QUEUE_IN_PUMA=true

# Shared secret for Rails → Go staff auth (generate once: openssl rand -hex 32)
GO_INTERNAL_SECRET=

# Super-ops system status page (/admin/systeme) — defaults to alaghabi98@gmail.com
# SUPER_OPS_EMAIL=alaghabi98@gmail.com

# ─── URLs ─────────────────────────────────────────────────────────────────────
SITE_URL=https://kideliowear.com
API_URL=https://kideliowear.com
FRONTEND_URL=https://kideliowear.com

# ─── Frontend build-time (baked into JS at deploy) ────────────────────────────
VITE_META_PIXEL_ID=1280844937142914
# WebSocket (chat, live cart, favorites) — run bash deploy/setup-ws.sh on VPS first
VITE_ENABLE_CHAT_WS=true

# ─── Meta Pixel + Conversions API ─────────────────────────────────────────────
META_PIXEL_ID=1280844937142914
# Full token from Events Manager → Settings → Generate access token (not stored in git)
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

# ─── Google OAuth (optional — copy from api/.env, change redirect URI for prod) ─
# Authorized redirect URI: https://kideliowear.com/users/auth/google_oauth2/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Go service ───────────────────────────────────────────────────────────────
# GO_SERVICE_URL is set in deploy/docker-compose.prod.yml (Rails proxies /api/v1/realtime → Go).
# ALLOWED_ORIGINS and RAILS_URL are set in deploy/docker-compose.prod.yml.
# Go data lives in Docker volume "go_service_data" (chat, cart events, favorites).
# Backup: bash deploy/backup-go-db.sh
