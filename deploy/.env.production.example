# ─── Rails ────────────────────────────────────────────────────────────────────
# Copy the contents of api/config/master.key (never commit that file!)
RAILS_MASTER_KEY=

# Generate with: docker compose -f deploy/docker-compose.prod.yml run --rm web rails secret
SECRET_KEY_BASE=

RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=true
RAILS_LOG_LEVEL=info

# Background jobs (Solid Queue inside Puma)
SOLID_QUEUE_IN_PUMA=true

# ─── URLs ─────────────────────────────────────────────────────────────────────
SITE_URL=https://kideliowear.com
API_URL=https://kideliowear.com
FRONTEND_URL=https://kideliowear.com

# ─── Frontend build-time (baked into JS at deploy) ────────────────────────────
VITE_META_PIXEL_ID=

# ─── Meta Pixel + Conversions API ─────────────────────────────────────────────
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

# ─── Google OAuth (optional — leave blank to disable) ─────────────────────────
# Authorized redirect URI: https://kideliowear.com/users/auth/google_oauth2/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Go service ───────────────────────────────────────────────────────────────
# ALLOWED_ORIGINS and RAILS_URL are set in deploy/docker-compose.prod.yml.
# Go data lives in Docker volume "go_service_data" (chat, cart events, favorites).
# Backup: bash deploy/backup-go-db.sh
