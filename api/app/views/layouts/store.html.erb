<!DOCTYPE html>
<html lang="fr">
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "Kids Shop" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="store-body">
    <header class="site-header">
      <%= link_to root_path, class: "logo" do %>
        <span>🧸</span> Kids Shop
      <% end %>
      <nav>
        <%= link_to "Produits", store_products_path %>
        <%= link_to "Contact", new_store_contact_path %>
        <% if current_user&.staff? %>
          <%= link_to "Admin", admin_root_path %>
        <% end %>
      </nav>
      <div class="header-actions">
        <% if current_user %>
          <%= link_to current_user.name, store_account_path %>
          <%= button_to "Déconnexion", store_session_path, method: :delete, class: "btn-link" %>
        <% else %>
          <%= link_to "Connexion", new_store_session_path %>
        <% end %>
        <%= link_to store_cart_path, class: "cart-link" do %>
          Panier <% if cart_count.positive? %><span class="badge"><%= cart_count %></span><% end %>
        <% end %>
      </div>
    </header>

    <%= render "shared/flash" %>

    <main class="site-main">
      <%= yield %>
    </main>

    <footer class="site-footer">
      <p>© <%= Time.current.year %> Kids Shop — Mode & jouets pour enfants</p>
    </footer>
  </body>
</html>
