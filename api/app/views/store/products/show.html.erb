<% content_for :title, @product.name %>
<div class="product-detail">
  <div class="product-gallery">
    <%= product_image(@product, css_class: "product-img large") %>
  </div>
  <div class="product-info">
    <h1><%= @product.name %></h1>
    <% if @product.age_group %><span class="tag"><%= @product.age_group %></span><% end %>
    <p class="price-lg"><%= format_tnd(@product.effective_price) %></p>
    <p><%= simple_format(@product.description) if @product.description.present? %></p>

    <% if @product.in_stock? %>
      <%= form_with url: store_cart_path, class: "add-cart-form" do %>
        <%= hidden_field_tag :product_id, @product.id %>
        <label>Quantité
          <%= number_field_tag :quantity, 1, min: 1, max: @product.stock %>
        </label>
        <%= submit_tag "Ajouter au panier", class: "btn btn-primary btn-lg" %>
      <% end %>
    <% else %>
      <p class="out-of-stock">Produit en rupture de stock</p>
    <% end %>
  </div>
</div>
