<h1>Produits <%= link_to "+ Nouveau", new_admin_product_path, class: "btn btn-primary" %></h1>
<table class="table">
  <tr><th>Nom</th><th>Prix</th><th>Stock</th><th></th></tr>
  <% @products.each do |p| %>
    <tr>
      <td><%= p.name %></td>
      <td><%= number_to_currency(p.price, unit: " TND", format: "%n%u", precision: 3) %></td>
      <td class="<%= 'warn' if p.stock < 5 %>"><%= p.stock %></td>
      <td><%= link_to "Voir", admin_product_path(p) %></td>
    </tr>
  <% end %>
</table>
