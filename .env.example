# ── Kids Shop — all apps share one Rails API ───────────────────────────────────
#
# Dev (npm run dev):
#   Rails API     http://localhost:3000   ← single source of truth (DB, auth, images)
#   Storefront    http://localhost:3001   ← proxies /api /rails /health → :3000
#   Admin         http://localhost:3002   ← same proxy, same API
#
# Session cookie _kids_shop_session is set per origin (3001 vs 3002) but both
# talk to the same database — admin login ≠ customer login (role check).

# Optional: override URLs returned by GET /api/v1/config
# STOREFRONT_URL=http://localhost:3001
# ADMIN_URL=http://localhost:3002

# Production React builds (no proxy) — set on web/admin before npm run build:
# REACT_APP_API_URL=https://api.your-domain.com
